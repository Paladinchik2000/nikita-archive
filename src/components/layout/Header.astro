---
import LanguageSwitcher from '../ui/LanguageSwitcher.astro';
import type { Locale } from '../../i18n/ui';
import { getAlternateLocaleUrl, getLocalizedUrl, stripLocaleFromPath, useTranslations } from '../../i18n/utils';

interface Props {
  lang?: Locale;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const navItems = [
  { href: '/', label: t('nav.home') },
  { href: '/about', label: t('nav.about') },
  { href: '/cinema', label: t('nav.cinema') },
  { href: '/library', label: t('nav.library') },
  { href: '/places', label: t('nav.places') },
  { href: '/projects', label: t('nav.projects') },
  { href: '/cv', label: t('nav.cv') },
];

const currentPath = stripLocaleFromPath(Astro.url.pathname);
const currentUrl = getLocalizedUrl(currentPath, lang);
const alternateUrl = getAlternateLocaleUrl(Astro.url.pathname, lang);
---

<header class="site-header">
  <a class="brand-mark" href={getLocalizedUrl('/', lang)} aria-label="Nikita Paladi home">
    <img src="/images/brand/logo-p.png" alt="" width="40" height="40" />
    <span>Nikita Paladi</span>
  </a>

  <nav class="site-nav" aria-label="Primary navigation">
    {
      navItems.map((item) => {
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isActive = currentPath === itemPath;

        return (
          <a href={getLocalizedUrl(item.href, lang)} aria-current={isActive ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })
    }
  </nav>

  <LanguageSwitcher lang={lang} currentUrl={currentUrl} alternateUrl={alternateUrl} />
</header>
