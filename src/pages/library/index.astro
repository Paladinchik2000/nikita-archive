---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';

const books = (await getCollection('books')).sort(
  (a, b) => (b.data.year ?? 0) - (a.data.year ?? 0),
);

const getEntrySlug = (entry) => entry.id;
---

<BaseLayout
  title="Library"
  description="Books, notes, ideas, and short reflections."
>
  <section class="page-hero">
    <p class="eyebrow">Reading</p>
    <h1>Library</h1>
    <p>Books, notes, ideas, and short reflections.</p>
  </section>

  <section class="page-section placeholder-grid" aria-label="Library entries">
    {
      books.map((book) => (
        <ArchiveCard
          title={book.data.title}
          description={book.data.description}
          href={`/library/${getEntrySlug(book)}`}
          eyebrow={book.data.author}
          cover={book.data.cover}
          meta={[book.data.year, book.data.rating && `${book.data.rating}/10`, book.data.favorite && 'Favorite']}
          chips={book.data.genres}
        />
      ))
    }
  </section>
</BaseLayout>
