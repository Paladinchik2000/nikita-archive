---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout
  title="About"
  description="About Nikita Paladi and the personal archive."
>
  <section class="page-hero">
    <p class="eyebrow">Personal Archive</p>
    <h1>About</h1>
    <p>
      This personal archive gathers notes, references, reviews, visited places,
      projects, and fragments of work into one calm, searchable home.
    </p>
  </section>

  <section class="page-section content-list" aria-label="About sections">
    <article class="text-panel glass-card">
      <h2>Background</h2>
      <p>
        A brief space for the story behind the archive, the work that shaped it,
        and the references that keep returning.
      </p>
    </article>
    <article class="text-panel glass-card">
      <h2>Interests</h2>
      <p>
        Cinema, books, cities, systems, visual culture, technology, and the
        useful tension between memory and documentation.
      </p>
    </article>
    <article class="text-panel glass-card">
      <h2>Current focus</h2>
      <p>
        Building a durable archive structure before expanding it with collections,
        essays, reviews, and richer project records.
      </p>
    </article>
  </section>
</BaseLayout>
