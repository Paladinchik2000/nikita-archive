---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';
import PlacesMap from '../../components/places/PlacesMap.astro';
import { getContentSlug, useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const places = (await getCollection('places')).filter((place) => place.data.lang === lang).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const getEntrySlug = (entry) => getContentSlug(entry);
const hasValidCoordinates = (coordinates) =>
  Array.isArray(coordinates)
  && coordinates.length === 2
  && coordinates.every((coordinate) => Number.isFinite(Number(coordinate)));
const mapPlaces = places
  .filter((place) => hasValidCoordinates(place.data.coordinates))
  .map((place) => ({
    title: place.data.title,
    location: [place.data.city, place.data.country].filter(Boolean).join(', '),
    description: place.data.description,
    href: `/places/${getEntrySlug(place)}`,
    coordinates: place.data.coordinates,
    mapZoom: place.data.mapZoom,
  }));
---

<BaseLayout
  title="Places"
  description="Visited places and future map notes."
  lang={lang}
>
  <section class="page-hero">
    <p class="eyebrow">Travel</p>
    <h1>Places</h1>
    <p>A map of places I have visited will live here.</p>
  </section>

  <PlacesMap places={mapPlaces} lang={lang} />

  <section class="page-section placeholder-grid" aria-label="Places entries">
    {
      places.map((place) => (
        <ArchiveCard
          title={place.data.title}
          description={place.data.description}
          href={`/places/${getEntrySlug(place)}`}
          eyebrow={place.data.country}
          cover={place.data.cover}
          meta={[place.data.city, place.data.visitedAt]}
          chips={place.data.tags}
          actionLabel={t('common.readNote')}
          noCoverLabel={t('common.noCover')}
        />
      ))
    }
  </section>
</BaseLayout>
