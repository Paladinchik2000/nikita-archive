---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';

export async function getStaticPaths() {
  const places = await getCollection('places');

  return places.map((place) => ({
    params: { slug: place.id },
    props: { place },
  }));
}

const { place } = Astro.props;
const { Content } = await render(place);
---

<BaseLayout
  title={place.data.title}
  description={place.data.description ?? `${place.data.title} place note.`}
>
  <a class="back-link" href="/places">Back to places</a>

  <section class="page-hero detail-hero">
    <p class="eyebrow">Places</p>
    <h1>{place.data.title}</h1>
    <div class="detail-meta">
      <span>{place.data.country}</span>
      {place.data.city && <span>{place.data.city}</span>}
      {place.data.visitedAt && <span>{place.data.visitedAt}</span>}
    </div>
    {place.data.tags && (
      <div class="chip-list">
        {place.data.tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    )}
    {place.data.description && <p>{place.data.description}</p>}
  </section>

  <article class="prose text-panel glass-card">
    <Content />
  </article>
</BaseLayout>
