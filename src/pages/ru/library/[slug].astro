---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import { getContentSlug, useTranslations } from '../../../i18n/utils';

const lang = 'ru';
const t = useTranslations(lang);

export async function getStaticPaths() {
  const books = (await getCollection('books')).filter((book) => book.data.lang === 'ru');

  return books.map((book) => ({
    params: { slug: getContentSlug(book) },
    props: { book },
  }));
}

const { book } = Astro.props;
const { Content } = await render(book);
const coverStyle = book.data.cover ? `--cover-image: url("${book.data.cover}")` : undefined;
---

<BaseLayout title={book.data.title} description={book.data.description ?? `${book.data.title} заметка о книге.`} lang={lang}>
  <a class="back-link" href="/ru/library">{t('common.back.library')}</a>

  <div class:list={['detail-cover', { 'has-cover': book.data.cover }]} style={coverStyle} aria-hidden="true">
    {!book.data.cover && <span>{t('common.noCover')}</span>}
  </div>

  <section class="page-hero detail-hero">
    <p class="eyebrow">Библиотека</p>
    <h1>{book.data.title}</h1>
    <div class="detail-meta">
      <span>{book.data.author}</span>
      {book.data.year && <span>{book.data.year}</span>}
      {book.data.rating && <span>{book.data.rating}/10</span>}
    </div>
    {book.data.genres && (
      <div class="chip-list">
        {book.data.genres.map((genre) => <span class="chip">{genre}</span>)}
      </div>
    )}
    {book.data.description && <p>{book.data.description}</p>}
  </section>

  <article class="prose text-panel glass-card">
    <Content />
  </article>
</BaseLayout>
