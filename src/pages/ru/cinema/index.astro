---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import ArchiveCard from '../../../components/ui/ArchiveCard.astro';
import { getContentSlug, useTranslations } from '../../../i18n/utils';

const lang = 'ru';
const t = useTranslations(lang);
const movies = (await getCollection('movies')).filter((movie) => movie.data.lang === lang).sort(
  (a, b) => b.data.year - a.data.year,
);

const getEntrySlug = (entry) => getContentSlug(entry);
---

<BaseLayout title="Кино" description="Фильмы, которые я смотрел, запомнил, ставил под вопрос или пересматривал." lang={lang}>
  <section class="page-hero">
    <p class="eyebrow">Отзывы</p>
    <h1>Кино</h1>
    <p>Фильмы, которые я смотрел, запомнил, ставил под вопрос или пересматривал.</p>
  </section>

  <section class="page-section placeholder-grid" aria-label="Записи о кино">
    {
      movies.map((movie) => (
        <ArchiveCard
          title={movie.data.title}
          description={movie.data.description}
          href={`/ru/cinema/${getEntrySlug(movie)}`}
          eyebrow={movie.data.year}
          cover={movie.data.cover}
          meta={[movie.data.rating && `${movie.data.rating}/10`, movie.data.favorite && t('common.favorite')]}
          chips={movie.data.genres}
          actionLabel={t('common.readNote')}
          noCoverLabel={t('common.noCover')}
        />
      ))
    }
  </section>
</BaseLayout>
