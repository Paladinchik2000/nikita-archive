---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import { getContentSlug, useTranslations } from '../../../i18n/utils';

const lang = 'ru';
const t = useTranslations(lang);

export async function getStaticPaths() {
  const places = (await getCollection('places')).filter((place) => place.data.lang === 'ru');

  return places.map((place) => ({
    params: { slug: getContentSlug(place) },
    props: { place },
  }));
}

const { place } = Astro.props;
const { Content } = await render(place);
const coverStyle = place.data.cover ? `--cover-image: url("${place.data.cover}")` : undefined;
const gallery = place.data.gallery ?? [];
---

<BaseLayout title={place.data.title} description={place.data.description ?? `${place.data.title} заметка о месте.`} lang={lang}>
  <a class="back-link" href="/ru/places">{t('common.back.places')}</a>

  <div class:list={['detail-cover', { 'has-cover': place.data.cover }]} style={coverStyle} aria-hidden="true">
    {!place.data.cover && <span>{t('common.noCover')}</span>}
  </div>

  <section class="page-hero detail-hero">
    <p class="eyebrow">Места</p>
    <h1>{place.data.title}</h1>
    <div class="detail-meta">
      <span>{place.data.country}</span>
      {place.data.city && <span>{place.data.city}</span>}
      {place.data.visitedAt && <span>{place.data.visitedAt}</span>}
    </div>
    {place.data.tags && (
      <div class="chip-list">
        {place.data.tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    )}
    {place.data.description && <p>{place.data.description}</p>}
  </section>

  <article class="prose text-panel glass-card">
    <Content />
  </article>

  <section class="page-section" aria-labelledby="place-gallery">
    <div class="section-heading">
      <p class="eyebrow">Фото</p>
      <h2 id="place-gallery">Галерея</h2>
    </div>
    {
      gallery.length > 0 ? (
        <div class="gallery-grid">
          {gallery.map((image, index) => (
            <div
              class="gallery-tile"
              style={`--gallery-image: url("${image}")`}
              aria-label={`${place.data.title}: изображение ${index + 1}`}
            />
          ))}
        </div>
      ) : (
        <div class="text-panel glass-card gallery-empty">
          <p>Фотографии появятся позже.</p>
        </div>
      )
    }
  </section>
</BaseLayout>
