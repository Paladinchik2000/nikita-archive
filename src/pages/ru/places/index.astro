---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import ArchiveCard from '../../../components/ui/ArchiveCard.astro';
import { getContentSlug, useTranslations } from '../../../i18n/utils';

const lang = 'ru';
const t = useTranslations(lang);
const places = (await getCollection('places')).filter((place) => place.data.lang === lang).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const getEntrySlug = (entry) => getContentSlug(entry);
---

<BaseLayout title="Места" description="Посещенные места и будущие заметки для карты." lang={lang}>
  <section class="page-hero">
    <p class="eyebrow">Путешествия</p>
    <h1>Места</h1>
    <p>Здесь позже появится карта мест, которые я посетил.</p>
  </section>

  <section class="page-section placeholder-grid" aria-label="Записи о местах">
    {
      places.map((place) => (
        <ArchiveCard
          title={place.data.title}
          description={place.data.description}
          href={`/ru/places/${getEntrySlug(place)}`}
          eyebrow={place.data.country}
          cover={place.data.cover}
          meta={[place.data.city, place.data.visitedAt]}
          chips={place.data.tags}
          actionLabel={t('common.readNote')}
          noCoverLabel={t('common.noCover')}
        />
      ))
    }
  </section>
</BaseLayout>
