---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import { getContentSlug, useTranslations } from '../../../i18n/utils';

const lang = 'ru';
const t = useTranslations(lang);

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).filter((project) => project.data.lang === 'ru');

  return projects.map((project) => ({
    params: { slug: getContentSlug(project) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const coverStyle = project.data.cover ? `--cover-image: url("${project.data.cover}")` : undefined;
---

<BaseLayout title={project.data.title} description={project.data.description ?? `${project.data.title} заметка о проекте.`} lang={lang}>
  <a class="back-link" href="/ru/projects">{t('common.back.projects')}</a>

  <div class:list={['detail-cover', { 'has-cover': project.data.cover }]} style={coverStyle} aria-hidden="true">
    {!project.data.cover && <span>{t('common.noCover')}</span>}
  </div>

  <section class="page-hero detail-hero">
    <p class="eyebrow">Проекты</p>
    <h1>{project.data.title}</h1>
    <div class="detail-meta">
      {project.data.year && <span>{project.data.year}</span>}
      {project.data.status && <span>{project.data.status}</span>}
    </div>
    {project.data.tags && (
      <div class="chip-list">
        {project.data.tags.map((tag) => <span class="chip">{tag}</span>)}
      </div>
    )}
    {project.data.description && <p>{project.data.description}</p>}
    <div class="external-links">
      {project.data.url && <a class="button button-secondary" href={project.data.url}>{t('common.openProject')}</a>}
      {project.data.github && <a class="button button-secondary" href={project.data.github}>{t('common.github')}</a>}
    </div>
  </section>

  <article class="prose text-panel glass-card">
    <Content />
  </article>
</BaseLayout>
