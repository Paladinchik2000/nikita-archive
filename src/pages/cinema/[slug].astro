---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';

export async function getStaticPaths() {
  const movies = await getCollection('movies');

  return movies.map((movie) => ({
    params: { slug: movie.id },
    props: { movie },
  }));
}

const { movie } = Astro.props;
const { Content } = await render(movie);
const coverStyle = movie.data.cover ? `--cover-image: url("${movie.data.cover}")` : undefined;
---

<BaseLayout
  title={movie.data.title}
  description={movie.data.description ?? `${movie.data.title} film note.`}
>
  <a class="back-link" href="/cinema">Back to cinema</a>

  <div class:list={['detail-cover', { 'has-cover': movie.data.cover }]} style={coverStyle} aria-hidden="true">
    {!movie.data.cover && <span>No cover yet</span>}
  </div>

  <section class="page-hero detail-hero">
    <p class="eyebrow">Cinema</p>
    <h1>{movie.data.title}</h1>
    <div class="detail-meta">
      <span>{movie.data.year}</span>
      {movie.data.rating && <span>{movie.data.rating}/10</span>}
      {movie.data.favorite && <span class="favorite-badge">Favorite</span>}
    </div>
    {movie.data.genres && (
      <div class="chip-list">
        {movie.data.genres.map((genre) => <span class="chip">{genre}</span>)}
      </div>
    )}
    {movie.data.description && <p>{movie.data.description}</p>}
  </section>

  <article class="prose text-panel glass-card">
    <Content />
  </article>
</BaseLayout>
