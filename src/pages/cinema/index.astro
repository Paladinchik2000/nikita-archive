---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';

const movies = (await getCollection('movies')).sort(
  (a, b) => b.data.year - a.data.year,
);

const getEntrySlug = (entry) => entry.id;
---

<BaseLayout
  title="Cinema"
  description="Films watched, remembered, questioned, or returned to."
>
  <section class="page-hero">
    <p class="eyebrow">Reviews</p>
    <h1>Cinema</h1>
    <p>Films I watched, remembered, questioned, or returned to.</p>
  </section>

  <section class="page-section placeholder-grid" aria-label="Cinema entries">
    {
      movies.map((movie) => (
        <ArchiveCard
          title={movie.data.title}
          description={movie.data.description}
          href={`/cinema/${getEntrySlug(movie)}`}
          eyebrow={movie.data.year}
          cover={movie.data.cover}
          meta={[movie.data.rating && `${movie.data.rating}/10`, movie.data.favorite && 'Favorite']}
          chips={movie.data.genres}
        />
      ))
    }
  </section>
</BaseLayout>
