---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';

const movies = (await getCollection('movies')).sort(
  (a, b) => b.data.year - a.data.year,
);

const getEntrySlug = (entry) => entry.id;
---

<BaseLayout
  title="Cinema"
  description="Films watched, remembered, questioned, or returned to."
>
  <section class="page-hero">
    <p class="eyebrow">Reviews</p>
    <h1>Cinema</h1>
    <p>Films I watched, remembered, questioned, or returned to.</p>
  </section>

  <section class="page-section placeholder-grid" aria-label="Cinema entries">
    {
      movies.map((movie) => (
        <a class="archive-card glass-card" href={`/cinema/${getEntrySlug(movie)}`}>
          <span class="card-eyebrow">{movie.data.year}</span>
          <h3>{movie.data.title}</h3>
          <div class="meta-row">
            {movie.data.rating && <span>{movie.data.rating}/10</span>}
            {movie.data.favorite && <span>Favorite</span>}
          </div>
          {movie.data.genres && (
            <div class="chip-list">
              {movie.data.genres.map((genre) => <span class="chip">{genre}</span>)}
            </div>
          )}
          {movie.data.description && <p>{movie.data.description}</p>}
          <span class="card-link">Read note</span>
        </a>
      ))
    }
  </section>
</BaseLayout>
