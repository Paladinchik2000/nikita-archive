---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';
import { getContentSlug, useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);
const projects = (await getCollection('projects')).filter((project) => project.data.lang === lang).sort(
  (a, b) => (b.data.year ?? 0) - (a.data.year ?? 0),
);

const getEntrySlug = (entry) => getContentSlug(entry);
---

<BaseLayout
  title="Projects"
  description="Selected projects, experiments, and things being built."
  lang={lang}
>
  <section class="page-hero">
    <p class="eyebrow">Making</p>
    <h1>Projects</h1>
    <p>Selected projects, experiments, and things I am building.</p>
  </section>

  <section class="page-section placeholder-grid" aria-label="Project entries">
    {
      projects.map((project) => (
        <ArchiveCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${getEntrySlug(project)}`}
          eyebrow={project.data.status ?? 'Project'}
          cover={project.data.cover}
          meta={[project.data.year]}
          chips={project.data.tags}
          actionLabel={t('common.readNote')}
          noCoverLabel={t('common.noCover')}
        />
      ))
    }
  </section>
</BaseLayout>
