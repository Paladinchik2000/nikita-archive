---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getContentSlug } from '../../i18n/utils';

const lang = 'en';
const projects = (await getCollection('projects'))
  .filter((project) => project.data.lang === lang)
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured) || (b.data.year ?? 0) - (a.data.year ?? 0));

const featuredProjects = projects.filter((project) => project.data.featured);
const getEntrySlug = (entry) => getContentSlug(entry);
const getChips = (project) => [...(project.data.stack ?? []), ...(project.data.tags ?? [])].slice(0, 6);
---

<BaseLayout
  title="Projects"
  description="A workspace for things I am building, testing, and learning from."
  lang={lang}
>
  <section class="page-hero">
    <p class="eyebrow">Making</p>
    <h1>Projects</h1>
    <p>A workspace for things I am building, testing, and learning from.</p>
  </section>

  {
    featuredProjects.length > 0 && (
      <section class="section-block" aria-labelledby="featured-projects">
        <div class="section-heading">
          <p class="eyebrow">Featured</p>
          <h2 id="featured-projects">Featured projects</h2>
        </div>
        <div class="project-grid">
          {featuredProjects.map((project) => (
            <article class="project-card glass-card">
              <a class="project-card-main" href={`/projects/${getEntrySlug(project)}`}>
                <span class="card-eyebrow">{project.data.status ?? 'Project'}</span>
                <h3>{project.data.title}</h3>
                <div class="meta-row">
                  {project.data.year && <span>{project.data.year}</span>}
                  {project.data.role && <span>{project.data.role}</span>}
                </div>
                {project.data.description && <p>{project.data.description}</p>}
                <div class="chip-list">
                  {getChips(project).map((chip) => <span class="chip">{chip}</span>)}
                </div>
                <span class="card-link">Read project</span>
              </a>
              <div class="external-links project-card-links">
                {project.data.url && <a class="button button-secondary" href={project.data.url}>Live Site</a>}
                {project.data.github && <a class="button button-secondary" href={project.data.github}>GitHub</a>}
              </div>
            </article>
          ))}
        </div>
      </section>
    )
  }

  <section class="page-section" aria-labelledby="all-projects">
    <div class="section-heading">
      <p class="eyebrow">Archive</p>
      <h2 id="all-projects">All projects</h2>
    </div>
    <div class="project-grid">
      {projects.map((project) => (
        <article class="project-card glass-card">
          <a class="project-card-main" href={`/projects/${getEntrySlug(project)}`}>
            <span class="card-eyebrow">{project.data.status ?? 'Project'}</span>
            <h3>{project.data.title}</h3>
            <div class="meta-row">
              {project.data.year && <span>{project.data.year}</span>}
              {project.data.role && <span>{project.data.role}</span>}
            </div>
            {project.data.description && <p>{project.data.description}</p>}
            <div class="chip-list">
              {getChips(project).map((chip) => <span class="chip">{chip}</span>)}
            </div>
            <span class="card-link">Read project</span>
          </a>
          <div class="external-links project-card-links">
            {project.data.url && <a class="button button-secondary" href={project.data.url}>Live Site</a>}
            {project.data.github && <a class="button button-secondary" href={project.data.github}>GitHub</a>}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
