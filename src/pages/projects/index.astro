---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import ArchiveCard from '../../components/ui/ArchiveCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => (b.data.year ?? 0) - (a.data.year ?? 0),
);

const getEntrySlug = (entry) => entry.id;
---

<BaseLayout
  title="Projects"
  description="Selected projects, experiments, and things being built."
>
  <section class="page-hero">
    <p class="eyebrow">Making</p>
    <h1>Projects</h1>
    <p>Selected projects, experiments, and things I am building.</p>
  </section>

  <section class="page-section placeholder-grid" aria-label="Project entries">
    {
      projects.map((project) => (
        <ArchiveCard
          title={project.data.title}
          description={project.data.description}
          href={`/projects/${getEntrySlug(project)}`}
          eyebrow={project.data.status ?? 'Project'}
          cover={project.data.cover}
          meta={[project.data.year]}
          chips={project.data.tags}
        />
      ))
    }
  </section>
</BaseLayout>
