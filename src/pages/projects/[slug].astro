---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getContentSlug, useTranslations } from '../../i18n/utils';

const lang = 'en';
const t = useTranslations(lang);

export async function getStaticPaths() {
  const projects = (await getCollection('projects')).filter((project) => project.data.lang === 'en');

  return projects.map((project) => ({
    params: { slug: getContentSlug(project) },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const coverStyle = project.data.cover ? `--cover-image: url("${project.data.cover}")` : undefined;
const dateRange = [project.data.startDate, project.data.endDate].filter(Boolean).join(' - ');
const stack = project.data.stack ?? [];
const tags = project.data.tags ?? [];
const highlights = project.data.highlights ?? [];
---

<BaseLayout
  title={project.data.title}
  description={project.data.description ?? `${project.data.title} project note.`}
  lang={lang}
>
  <a class="back-link" href="/projects">{t('common.back.projects')}</a>

  <div class:list={['detail-cover', { 'has-cover': project.data.cover }]} style={coverStyle} aria-hidden="true">
    {!project.data.cover && <span>{t('common.noCover')}</span>}
  </div>

  <section class="page-hero detail-hero">
    <p class="eyebrow">Projects</p>
    <h1>{project.data.title}</h1>
    <div class="detail-meta">
      {project.data.status && <span>{project.data.status}</span>}
      {project.data.year && <span>{project.data.year}</span>}
      {dateRange && <span>{dateRange}</span>}
      {project.data.role && <span>{project.data.role}</span>}
    </div>
    {project.data.description && <p>{project.data.description}</p>}
    <div class="external-links">
      {project.data.url && <a class="button button-primary" href={project.data.url}>Live Site</a>}
      {project.data.github && <a class="button button-secondary" href={project.data.github}>GitHub</a>}
    </div>
  </section>

  <section class="project-detail-grid">
    <article class="text-panel glass-card">
      <h2>Stack</h2>
      <div class="chip-list">
        {[...stack, ...tags].map((chip) => <span class="chip">{chip}</span>)}
      </div>
    </article>
    <article class="text-panel glass-card">
      <h2>Highlights</h2>
      {
        highlights.length > 0 ? (
          <ul class="clean-list">
            {highlights.map((highlight) => <li>{highlight}</li>)}
          </ul>
        ) : (
          <p>Highlights can be added later.</p>
        )
      }
    </article>
  </section>

  <article class="prose text-panel glass-card">
    <Content />
  </article>
</BaseLayout>
